{
  "name": "solcial-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Solcial - Social Media on Solana Monorepo",
  "scripts": {
    "mobile": "cd apps/mobile && pnpm start",
    "backend": "cd apps/backend && pnpm start:dev",
    "mobile:install": "cd apps/mobile && pnpm install",
    "backend:install": "cd apps/backend && pnpm install",
    "install:all": "pnpm mobile:install && pnpm backend:install"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0"
}
